@startuml
title Dataset Lifecycle
[*] --> REQUESTED
REQUESTED --> CONFIGURED
CONFIGURED --> SOURCE_RESOLVED
SOURCE_RESOLVED --> DOWNLOADING
DOWNLOADING --> DOWNLOADED
DOWNLOADED --> ARCHIVED
ARCHIVED --> PARSED
PARSED --> VALIDATED
VALIDATED --> TRANSFORMED
TRANSFORMED --> LOADED
LOADED --> VERIFIED
VERIFIED --> COMPLETED
REQUESTED --> FAILED
CONFIGURED --> FAILED
SOURCE_RESOLVED --> FAILED
DOWNLOADING --> FAILED
DOWNLOADED --> FAILED
ARCHIVED --> FAILED
PARSED --> FAILED
VALIDATED --> FAILED
TRANSFORMED --> FAILED
LOADED --> FAILED
VERIFIED --> FAILED
COMPLETED --> [*]
FAILED --> [*]
@enduml
